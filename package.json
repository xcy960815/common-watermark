{
  "name": "common-watermark",
  "version": "0.1.0",
  "description": "一个轻量、框架无关的浏览器端水印库。",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.esm.js",
  "types": "./types/index.d.ts",
  "files": [
    "dist",
    "types",
    "README.md",
    "README.zh-CN.md"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.umd.js",
      "default": "./dist/index.umd.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "rollup -c",
    "check": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "preview": "vite preview"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xcy960815/common-watermark.git"
  },
  "author": {
    "name": "xcy960815",
    "email": "18763006837@163.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/xcy960815/common-watermark/issues"
  },
  "homepage": "https://xcy960815.github.io/common-watermark/",
  "keywords": [
    "watermark",
    "frontend-watermark",
    "浏览器水印",
    "前端水印"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.8.0",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "rollup": "^4.44.1",
    "rollup-plugin-dts": "^6.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^5.4.10",
    "vitepress": "^1.3.4"
  }
}
